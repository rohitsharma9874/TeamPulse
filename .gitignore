# .gitignore for TeamPulse

# Build outputs
**/bin/
**/obj/

# User-specific files
.vs/
*.user
*.userosscache
*.suo

# ASP.NET Core generated
*.db
*.bak
*.log

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# OS files
Thumbs.db
.DS_Store

# Secrets — never commit real credentials
appsettings.Development.json
appsettings.Production.json
appsettings.*.secrets.json

# Angular
node_modules/
dist/
.angular/
.npm/

# Uploaded files (user content — never commit)
uploads/

# Local dev scripts/test bodies
body.json
verify-task.ps1
